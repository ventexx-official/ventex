# Ventex Environment Variables Template
# Copy this to .env.local and fill in your actual values.

# Supabase Auth & Database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI integrations (Fallback system: Gemini -> OpenAI -> DeepSeek)
GEMINI_API_KEY=your_google_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# Stripe Integration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# News API Integrations
NEWS_API_KEY=your_news_api_key
HACKERNEWS_API_URL=https://hacker-news.firebaseio.com/v0/

# Site configuration
NEXT_PUBLIC_BASE_URL=https://ventexx.com
NEXT_PUBLIC_APP_NAME=Ventexx

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
