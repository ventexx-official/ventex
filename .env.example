# Ventex Environment Variables Template
# Copy this to .env.local and fill in your actual values.

# Supabase Auth & Database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# IMPORTANT: The Service Role Key is required for backend API routes (e.g., scoring, admin tasks)
# It bypasses Row Level Security. Never expose this to the browser!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google / AI integrations
GEMINI_API_KEY=your_google_gemini_api_key

# Stripe Integration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Note: STRIPE_PRICE_VENTEX_ACCESS is no longer used/required.

# Site configuration
NEXT_PUBLIC_BASE_URL=https://ventexx.com
NEXT_PUBLIC_APP_NAME=Ventexx

# Vercel Configuration (if any custom vars needed)
# VERCEL_URL is automatically set by Vercel in deployment.
